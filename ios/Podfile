# Uncomment this line to define a global platform for your project
 platform :ios, '14.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  razorpay_xcframework_scripts = [
    File.join(
      __dir__,
      'Pods',
      'Target Support Files',
      'razorpay-core-pod',
      'razorpay-core-pod-xcframeworks.sh'
    ),
    File.join(
      __dir__,
      'Pods',
      'Target Support Files',
      'razorpay-pod',
      'razorpay-pod-xcframeworks.sh'
    )
  ]

  dsym_copy_snippet = <<~'SH'

  copy_dsym() {
    local source="$1"

    if [ -z "${DWARF_DSYM_FOLDER_PATH:-}" ] || [ ! -d "$source" ]; then
      return
    fi

    mkdir -p "${DWARF_DSYM_FOLDER_PATH}"
    copy_dir "$source" "${DWARF_DSYM_FOLDER_PATH}"
    echo "Copied $source to ${DWARF_DSYM_FOLDER_PATH}"
  }
  SH

  razorpay_xcframework_scripts.each do |script_path|
    next unless File.exist?(script_path)

    contents = File.read(script_path)
    next if contents.include?('copy_dsym()')

    updated_contents = contents.sub(
      'SELECT_SLICE_RETVAL=""',
      "#{dsym_copy_snippet}\nSELECT_SLICE_RETVAL=\"\""
    )

    updated_contents = updated_contents.gsub(
      /^(\s*copy_dir "\$source\/" "\$destination"\n\s*echo "Copied \$source to \$destination")$/,
      "\\1\n\n  copy_dsym \"$basepath/$target_path/dSYMs\""
    )

    File.write(script_path, updated_contents) if updated_contents != contents
  end

  package_info_plus_umbrella = File.join(
    __dir__,
    'Pods',
    'Target Support Files',
    'package_info_plus',
    'package_info_plus-umbrella.h'
  )

  if File.exist?(package_info_plus_umbrella)
    contents = File.read(package_info_plus_umbrella)
    updated_contents = contents.gsub(
      '#import "FPPPackageInfoPlusPlugin.h"',
      '#import <package_info_plus/FPPPackageInfoPlusPlugin.h>'
    )

    File.write(package_info_plus_umbrella, updated_contents) if updated_contents != contents
  end
end
